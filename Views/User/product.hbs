<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Bootstrap CSS from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Your custom CSS -->
    <link rel="stylesheet" href="/Style/user/product.css">

    <title>Product Name</title>
</head>

<body>



    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <img id="logo-img" src="/Images/Logo/secondary_logo_without_bg.webp" alt="CHRONIX">
            </a>
            <div class="d-flex">
                <form class="d-flex me-3">
                    <p class="navbar_username mb-0"><a href="/user/login" class="text-decoration-none text-white">LOG
                            IN</a></p>
                </form>
            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <div class="d-flex">
        <!-- Sidebar -->
        <div id="sidebar" class="col-md-3 sidebar">
            <ul class="list-unstyled">
                <li id="home" class="sidebar-item"><a href="/user/home" class="text-decoration-none"><i
                            class="bi bi-house-door"></i><span class="item-text">Home</span></a></li>
                <li id="explore" class="sidebar-item"><a href="/user/explore" class="text-decoration-none"><i
                            class="bi bi-compass"></i><span class="item-text">Explore</span></a></li>
                <li id="wishlist" class="sidebar-item"><a href="/user/wishlist" class="text-decoration-none"><i
                            class="bi bi-heart"></i><span class="item-text">Wishlist</span></a></li>
                <li id="cart" class="sidebar-item"><a href="/user/cart" class="text-decoration-none"><i
                            class="bi bi-cart2"></i><span class="item-text">Cart</span></a></li>
                <li id="profile" class="sidebar-item"><a href="/user/profile" class="text-decoration-none"><i
                            class="bi bi-person"></i><span class="item-text">Profile</span></a></li>
                <li id="orders" class="sidebar-item"><a href="/user/orders" class="text-decoration-none"><i
                            class="bi bi-clock-history"></i><span class="item-text">Orders</span></a></li>
                <li id="reviews" class="sidebar-item"><a href="/user/reviews" class="text-decoration-none"><i
                            class="bi bi-chat-left-text"></i><span class="item-text">Reviews</span></a></li>
                <li id="wallet" class="sidebar-item"><a href="/user/wallet" class="text-decoration-none"><i
                            class="bi bi-wallet"></i><span class="item-text">Wallet</span></a></li>
                <li id="logout" class="sidebar-item"><a href="/user/logout" class="text-decoration-none"><i
                            class="bi bi-box-arrow-right"></i><span class="item-text">Logout</span></a></li>
            </ul>
        </div>

        <div class="container-fluid">
            <!-- Main Content -->
            <div class="col-12 main-content" style="overflow-y: scroll; max-height: 500px; scrollbar-width: 20px;">
                <div class="container-fluid">
                    <div class="row">
                        <!-- Product Image -->
                        <div class="col-md-3">
                            <div class="product-image"
                                style="overflow-y: scroll; max-height: 300px; scrollbar-width: 20px;">
                                <img src="/Images/Watches/SLGH005G.png" alt="SBGD215 Watch"
                                    class="img-fluid watch-image">
                                <img src="/Images/Watches/SLGH005G.png" alt="SBGD215 Watch"
                                    class="img-fluid watch-image">
                                <img src="/Images/Watches/SLGH005G.png" alt="SBGD215 Watch"
                                    class="img-fluid watch-image">
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="col-md-9">
                            <div class="product-info"
                                style="overflow-y: scroll; max-height: 300px; scrollbar-width: 20px;">
                                <h2>SBGD215 - Spring Drive 8-Day Masterpiece Jewelry Watch</h2>
                                <div class="price-section">
                                    <h3>MRP ₹ 25,000,000.00</h3>
                                    <div class="d-flex align-items-center gap-3 mt-3">
                                        <div class="quantity-control">
                                            <button class="btn text-white p-0" onclick="decreaseQuantity()"><i
                                                    class="bi bi-dash-circle"></i></button>
                                            <span id="quantity">1</span>
                                            <button class="btn text-white p-0" onclick="increaseQuantity()"><i
                                                    class="bi bi-plus-circle"></i></button>
                                        </div>


                                        <button class="add-to-cart">Add to Cart</button>
                                    </div>
                                </div>

                                <p class="text-secondary">Exuding strength and dignity, the lion symbol has been
                                    associated with
                                    Grand Seiko since the first watch in 1960, representing the strong desire to create
                                    the best
                                    possible watch. Today, the timeless lion emblem carries forth the enduring spirit of
                                    Grand
                                    Seiko, marching steadily forward into a future that stays true to the sublime roots
                                    of a
                                    design based on the lion theme.</p>

                                <div class="specs mt-4">
                                    <div class="spec-row">
                                        <span class="spec-label">Material</span>
                                        <span>Platinum</span>
                                    </div>
                                    <div class="spec-row">
                                        <span class="spec-label">Band Material</span>
                                        <span>Crocodile leather</span>
                                    </div>
                                    <div class="spec-row">
                                        <span class="spec-label">Water Resistance</span>
                                        <span>50 bar</span>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>

                    <!-- Tabs Section -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <!-- Tab-style buttons -->
                            <div class="custom-tabs">
                                <div class="tab-buttons-container">
                                    <button class="tab-button active" onclick="showContent('description')">
                                        <i class="bi bi-file-text me-1"></i>Description
                                    </button>
                                    <button class="tab-button" onclick="showContent('reviews')">
                                        <i class="bi bi-star me-1"></i>Reviews
                                    </button>
                                </div>
                            </div>

                            <!-- Content sections -->
                            <div class="tab-content-container">
                                <div id="description-content" class="content-section">
                                    <h4>Origins</h4>
                                    <p>Exuding strength and dignity, the lion symbol has been associated with Grand
                                        Seiko since
                                        the first watch in 1960. Today, the timeless lion emblem carries forth the
                                        enduring
                                        spirit of Grand Seiko, marching steadily forward into a future that stays true
                                        to the
                                        sublime roots of a design based on the lion theme.</p>
                                    <p>Limited Edition of 8 pieces Worldwide</p>
                                </div>

                                <div id="reviews-content" class="content-section" style="display: none;">
                                    <h4>Customer Reviews</h4>
                                    <p>No reviews yet</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Related Products -->
                    <div class="related-products">
                        <h3 class="mb-4">Related Products</h3>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="related-product-card">
                                    <img src="/Images/Watches/SLGW002J.png" alt="Related Watch 1">
                                    <h5>SLGH005G</h5>
                                    <p class="text-secondary">Price: ₹ 8,50,000.00</p>
                                    <button class="btn btn-outline-light btn-sm"><i
                                            class="bi bi-cart-plus"></i></button>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="related-product-card">
                                    <img src="/Images/Watches/SLGW003G.png" alt="Related Watch 2">
                                    <h5>SLGH002G</h5>
                                    <p class="text-secondary">Price: ₹ 9,20,000.00</p>
                                    <button class="btn btn-outline-light btn-sm"><i
                                            class="bi bi-cart-plus"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script>


        const toggleButton = document.getElementById('logo-img');
        const sidebar = document.getElementById('sidebar');

        toggleButton.addEventListener('click', function () {
            sidebar.classList.toggle('minimized');
        });

        // Minimize sidebar by default for small screens on page load
        if (window.innerWidth <= 768) {
            sidebar.classList.add('minimized');
        }

        // Adjust when window is resized (optional, but good for UX)
        window.addEventListener('resize', function () {
            if (window.innerWidth <= 768) {
                sidebar.classList.add('minimized');
            } else {
                sidebar.classList.remove('minimized');
            }
        });

        function showContent(contentType) {
            // Hide all content sections
            const contentSections = document.querySelectorAll('.content-section');
            contentSections.forEach(section => {
                section.style.display = 'none';
            });

            // Show the selected content
            document.getElementById(contentType + '-content').style.display = 'block';

            // Update button styles
            const buttons = document.querySelectorAll('.tab-button');
            buttons.forEach(button => {
                button.classList.remove('active');
                if (button.textContent.toLowerCase().includes(contentType)) {
                    button.classList.add('active');
                }
            });
        }

        // Add active class to the first tab on page load
        document.addEventListener('DOMContentLoaded', () => {
            showContent('description');
        });


        let quantity = 1;

        function increaseQuantity() {
            quantity++;
            document.getElementById("quantity").innerText = quantity;
        }

        function decreaseQuantity() {
            if (quantity > 1) {
                quantity--;
                document.getElementById("quantity").innerText = quantity;
            }
        }


    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

</body>

</html>